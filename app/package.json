{
	"name": "map-making-app",
	"private": true,
	"version": "0.3.1",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"lint": "eslint .",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"bench": "vitest bench --run",
		"build:e2e": "set VITE_E2E=1&& cargo tauri build --debug --features e2e",
		"test:e2e": "set MMA_TEST_DB=1&& wdio run wdio.conf.ts",
		"test:e2e:log": "powershell -Command \"$f = 'test/logs/e2e-' + (Get-Date -Format 'yyyy-MM-ddTHH-mm-ss') + '.txt'; wdio run wdio.conf.ts 2>&1 | Tee-Object -FilePath $f\"",
		"prepare": "husky || true"
	},
	"dependencies": {
		"@deck.gl/core": "^9.3.1",
		"@deck.gl/google-maps": "^9.3.1",
		"@deck.gl/layers": "^9.3.1",
		"@mdi/js": "^7.4.47",
		"@photostructure/tz-lookup": "^11.5.0",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-toggle": "^1.1.10",
		"@radix-ui/react-toggle-group": "^1.1.11",
		"@radix-ui/react-visually-hidden": "^1.2.4",
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/plugin-dialog": "^2.7.1",
		"@tauri-apps/plugin-log": "^2.8.0",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-shell": "^2.3.5",
		"@tauri-apps/plugin-updater": "^2.10.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"measuretool-googlemaps-v3": "^1.0.2",
		"react": "^19.2.5",
		"react-colorful": "^5.6.1",
		"react-dom": "^19.2.5"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tauri-apps/cli": "^2.10.1",
		"@types/google.maps": "^3.64.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^24.12.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"@wdio/cli": "^9.27.1",
		"@wdio/local-runner": "^9.27.1",
		"@wdio/mocha-framework": "^9.27.1",
		"@wdio/spec-reporter": "^9.27.1",
		"@wdio/types": "^9.27.1",
		"eslint": "^10.2.1",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.5.0",
		"prettier": "^3.8.3",
		"typescript": "~6.0.2",
		"typescript-eslint": "^8.58.2",
		"vite": "^7.3.2",
		"vitest": "^3.2.4",
		"webdriverio": "^9.27.1"
	}
}
