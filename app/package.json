{
	"name": "map-making-app",
	"private": true,
	"version": "0.7.4",
	"type": "module",
	"scripts": {
		"gen:plugin-types": "node ../plugins/types/generate.js",
		"gen:plugin-registry": "node ../plugins/generate-registry.js",
		"gen:image-dims": "node scripts/gen-image-dims.mjs",
		"gen:bindings": "cargo run --manifest-path src-tauri/Cargo.toml -- --export-bindings",
		"proto:gen": "pbf src/lib/sv/proto/getmetadata.proto > src/lib/sv/proto/getmetadata.gen.js",
		"dev": "vite",
		"build": "npm run gen:plugin-types && npm run gen:plugin-registry && npm run gen:image-dims && vite build",
		"build:opensv": "node opensv-build/build-opensv.mjs",
		"format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"test/**/*.{ts,tsx}\" && cargo fmt --manifest-path src-tauri/Cargo.toml",
		"lint": "eslint .",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"bench": "vitest bench --run",
		"build:e2e": "cargo tauri build --debug --features e2e",
		"test:e2e": "wdio run wdio.conf.ts",
		"prepare": "husky || true"
	},
	"dependencies": {
		"@deck.gl/core": "^9.3.1",
		"@deck.gl/google-maps": "^9.3.1",
		"@deck.gl/layers": "^9.3.1",
		"@deck.gl/mapbox": "^9.3.6",
		"@mdi/js": "^7.4.47",
		"@photostructure/tz-lookup": "^11.5.0",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-tooltip": "^1.2.10",
		"@radix-ui/react-visually-hidden": "^1.2.4",
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/plugin-dialog": "^2.7.1",
		"@tauri-apps/plugin-log": "^2.8.0",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-shell": "^2.3.5",
		"@tauri-apps/plugin-updater": "^2.10.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"maplibre-gl": "^5.24.0",
		"measuretool-googlemaps-v3": "^1.0.2",
		"pbf": "^5.1.0",
		"react": "^19.2.5",
		"react-colorful": "^5.6.1",
		"react-day-picker": "^10.0.1",
		"react-dom": "^19.2.5",
		"ts-pattern": "^5.9.0"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"prettier --write",
			"eslint --fix"
		],
		"*.{json,css,md}": "prettier --write"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@mdx-js/rollup": "^3.1.1",
		"@tauri-apps/cli": "^2.10.1",
		"@types/google.maps": "^3.64.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^24.12.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native": "npm:typescript@~7.0.2",
		"@vitejs/plugin-react": "^5.2.0",
		"@wdio/cli": "^9.27.1",
		"@wdio/local-runner": "^9.27.1",
		"@wdio/mocha-framework": "^9.27.1",
		"@wdio/spec-reporter": "^9.27.1",
		"@wdio/types": "^9.27.1",
		"dts-bundle-generator": "^9.5.1",
		"eslint": "^10.2.1",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"fast-check": "^4.9.0",
		"globals": "^17.5.0",
		"image-size": "^2.0.2",
		"jsdom": "^27.0.1",
		"lint-staged": "^17.0.5",
		"prettier": "^3.8.3",
		"terser": "^5.47.1",
		"typescript": "npm:@typescript/typescript6@^6.0.2",
		"typescript-eslint": "^8.58.2",
		"vite": "^7.3.2",
		"vitest": "^3.2.4",
		"webdriverio": "^9.27.1"
	}
}
