{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "enables the default permissions",
	"windows": ["main", "map-*"],
	"permissions": [
		"core:default",
		"core:webview:allow-create-webview-window",
		"core:window:allow-set-focus",
		"core:window:allow-is-minimized",
		"core:window:allow-unminimize",
		"core:window:allow-destroy",
		"core:window:allow-show",
		"core:window:allow-is-fullscreen",
		"core:window:allow-set-fullscreen",
		"core:window:allow-set-title",
		"window-state:default",
		"log:default",
		{
			"identifier": "shell:allow-execute",
			"allow": [
				{ "name": "vali", "cmd": "vali", "args": true },
				{ "name": "mma-vision", "cmd": "mma-vision", "args": true },
				{ "name": "sh", "cmd": "sh", "args": true },
				{ "name": "bash", "cmd": "bash", "args": true },
				{ "name": "cmd", "cmd": "cmd", "args": true },
				{ "name": "powershell", "cmd": "powershell", "args": true },
				{ "name": "pwsh", "cmd": "pwsh", "args": true }
			]
		},
		{
			"identifier": "shell:allow-spawn",
			"allow": [
				{ "name": "vali", "cmd": "vali", "args": true },
				{ "name": "mma-vision", "cmd": "mma-vision", "args": true },
				{ "name": "sh", "cmd": "sh", "args": true },
				{ "name": "bash", "cmd": "bash", "args": true },
				{ "name": "cmd", "cmd": "cmd", "args": true },
				{ "name": "powershell", "cmd": "powershell", "args": true },
				{ "name": "pwsh", "cmd": "pwsh", "args": true }
			]
		},
		"shell:allow-stdin-write",
		"shell:allow-kill",
		"shell:allow-open",
		"dialog:default",
		"updater:default",
		"process:default"
	]
}
